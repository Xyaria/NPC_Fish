	// ---------- Fish Descriptions
		// Vanilla - fish
	"NPCFish.Desc.Abigail": "This weird fish derives sustenance from mountain rocks and minerals.",
	"NPCFish.Desc.Alex": "That is one big buff fish!",
	"NPCFish.Desc.Caroline": "This fish nests in the middle of algae which it takes care and feeds off of.",
	"NPCFish.Desc.Clint": "It possesses very hard scales with a metallic shine.",
	"NPCFish.Desc.Demetrius": "Its elastic scales allows it to resist the harsh sea floor conditions and clean it.",
	"NPCFish.Desc.Dwarf": "It used its hardened tentacles to dig through rocks to nest.",
	"NPCFish.Desc.Elliott": "The tail of this eel possesses a soft and feathery tip.",
	"NPCFish.Desc.Emily": "Under the sun, its iridescent scales shine beautifully.",
	"NPCFish.Desc.Evelyn": "It swims just under the surface to enjoy the sun.",
	"NPCFish.Desc.George": "Its round fins allows this sedimentary fish to 'roll' on the sea floor.",
	"NPCFish.Desc.Gus": "When it deflates, a curious smell of tomato sauce fills the air.",
	"NPCFish.Desc.Haley": "A curious little crab who loves stealing coconuts.",
	"NPCFish.Desc.Harvey": "Just holding it in your hands is enough to make you feel in better shape.",
	"NPCFish.Desc.Jas": "When seen from behind, its fins looks like a beautiful butterfly.",
	"NPCFish.Desc.Jodi": "This fish is obssessed with maintaining a clean nesting environnment.",
	"NPCFish.Desc.Kent": "Its jaw is lined with hard scales, which it snaps in self-defence.",
	"NPCFish.Desc.Krobus": "It's almost impossible to hold it with how intangible it is.",
	"NPCFish.Desc.Leah": "The stains on its fins are from crushed corals, which it uses to paint its nest.",
	"NPCFish.Desc.Leo": "A unique variant of the blue discus, believed to have been sole responsible of the sandiness of Ginger Island.",
	"NPCFish.Desc.Lewis": "It is often found around other fish, enjoying their hard work for itself.",
	"NPCFish.Desc.Linus": "Quite nomadic, this little snail shell holds a very comfortable and transportable nest.",
	"NPCFish.Desc.Marnie": "A curious fish that can be seen herding around other fish.",
	"NPCFish.Desc.Maru": "Its tentacles can give electric shocks if you touch them.",
	"NPCFish.Desc.Pam": "Once out of the water, it exudes a weird ale-like liquid reeking of alcohol.",
	"NPCFish.Desc.Penny": "Its dorsal fin has a different, hardback texture.",
	"NPCFish.Desc.Pierre": "Its wide jaw is used to carry shinies back to its hoard pile.",
	"NPCFish.Desc.Robin": "This peculiar fish builds nests out of pieces of driftwood.",
	"NPCFish.Desc.Sam": "It has hardened but soft to the touch dorsal fins.",
	"NPCFish.Desc.Sandy": "This fish has flower petals stuck between its scales.",
	"NPCFish.Desc.Sebastian": "With how often this fish hides between rocks, it's a miracle you caught it.",
	"NPCFish.Desc.Shane": "It uses its tentacles to hide when stressed out.",
	"NPCFish.Desc.Vincent": "An energetic little fish who is often found around snails.",
	"NPCFish.Desc.Willy": "The fishiest fish to ever fish.",
	"NPCFish.Desc.Wizard ": "Water seemed disformed around this fish, as if something tried to manipulate it.",

			// Vanilla - crabpot
	"NPCFish.Desc.Bear": "A friend-shaped clam, but beware: it bites.",
	"NPCFish.Desc.Birdie": "This curious seaweed seemed to have travelled around the world.",
